# Backend Environment Variables (env.properties example)
# Copy content to env.properties and configure for your database

# Database Configuration
DB_URL=jdbc:postgresql://your-host:5433/postgres
DB_USERNAME=postgres.your-project-id
DB_PASSWORD=your-password

# Supabase Configuration (for backend services if needed)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key
SUPABASE_BUCKET=RoomImages

# Server Configuration
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/

# Spring Boot Configuration
SPRING_PROFILES_ACTIVE=prod
