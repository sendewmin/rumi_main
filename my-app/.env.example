# Frontend Environment Variables (.env example)
# Copy this to .env and fill in your actual values

# Supabase Configuration (for authentication only)
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key-here

# Backend API Configuration
# The frontend axios client automatically uses /api baseURL
# When running locally, make sure backend is on http://localhost:8080
# For production, you may need to set the full API URL
REACT_APP_API_BASE_URL=http://localhost:8080/api
