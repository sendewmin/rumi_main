{
  "name": "my-app",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@mui/material": "^7.3.7",
    "@mui/utils": "^7.3.9",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "axios": "^1.13.6",
    "google-map-react": "^2.2.5",
    "lucide-react": "^0.563.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.13.1",
    "react-scripts": "5.0.1",
    "swiper": "^12.1.2",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "test:ci": "react-scripts test --watchAll=false --passWithNoTests",
    "eject": "react-scripts eject"
  },
  "jest": {
    "moduleNameMapper": {
      "^swiper/react$": "my-app/src/__mocks__/swiper-react.js",
      "^swiper/modules$": "my-app/src/__mocks__/swiper-modules.js",
      "^swiper/css$": "my-app/src/__mocks__/swiper-css.js",
      "^swiper/css/(.*)$": "my-app/src/__mocks__/swiper-css.js"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(swiper|ssr-window|dom7)/)"
    ]
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.0"
  }
}
